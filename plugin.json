{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-agent-codex",
  "name": {
    "en": "Codex",
    "ko": "Codex"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-agent-codex.git",
  "description": {
    "ko": "새 탭(+) 메뉴 에이전트 카테고리에 Codex CLI 를 추가 — 미설치면 공식 설치 명령을 터미널에서 실행한 뒤 사용",
    "en": "Adds Codex CLI under the Agents category of the new-tab (+) menu — runs the official installer in a terminal if missing"
  },
  "entry": "main.js",
  "permissions": [
    "programs",
    "commands",
    "process"
  ],
  "contributes": {
    "commands": [
      {
        "name": "status",
        "title": {
          "ko": "설치 상태 조회",
          "en": "Installation status"
        }
      },
      {
        "name": "install",
        "title": {
          "ko": "지금 설치 실행",
          "en": "Run installer now"
        }
      }
    ],
    "programs": [
      {
        "id": "codex",
        "title": "Codex",
        "path": {
          "ko": "에이전트",
          "en": "Agents"
        },
        "kind": "view",
        "viewContract": {
          "id": "soksak-spec-plugin-terminal",
          "range": "0.0.1"
        },
        "view": "content",
        "command": "codex",
        "ensure": {
          "bin": "codex",
          "install": {
            "darwin": "curl -fsSL https://chatgpt.com/codex/install.sh | sh",
            "linux": "curl -fsSL https://chatgpt.com/codex/install.sh | sh",
            "win32": "irm https://chatgpt.com/codex/install.ps1 | iex"
          }
        }
      }
    ]
  }
}
